# Copie para deploy-lightsail.env e preencha. NÃO comitar (já está no .gitignore).
# Dados do Lightsail Managed Database (passo 1 do DEPLOY_AWS_LIGHTSAIL.md):
DB_ENDPOINT=bora-db.xxxxxx.sa-east-1.rds.amazonaws.com
DB_NAME=bora
DB_USER=dbmasteruser
DB_PASSWORD=troque-esta-senha

# Segredo de assinatura do JWT — mínimo 32 bytes (gere com: openssl rand -base64 48)
BORA_JWT_SECRET=troque-por-um-segredo-forte-de-32-bytes-ou-mais

# Admin inicial (criado no 1º start se não houver usuários):
ADMIN_EMAIL=admin@bora.app
ADMIN_SENHA=troque-esta-senha

# Origem do frontend para CORS. Comece com * e troque pela URL real após criar a Distribution.
CORS_ORIGINS=*
